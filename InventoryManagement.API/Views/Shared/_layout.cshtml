<!DOCTYPE html>
<html>

<head>
    <title>Inventory System</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" rel="stylesheet">



    <link rel="stylesheet" href="@Url.Content("~/css/site.css")" />

    <style>
            .sidebar {
                width: 240px;
                background: #1f2937;
                color: white;
                min-height: 100vh;
            }

            .menu-title {
                padding: 10px 15px;
                cursor: pointer;
                background: #374151;
                border-bottom: 1px solid #4b5563;
            }

            .menu-title:hover {
                background: #4b5563;
            }

            .menu-link {
                display: block;
                padding: 10px 15px;
                color: white;
                text-decoration: none;
            }

            .menu-link:hover {
                background: #4b5563;
            }

            .submenu {
                display: none;
                padding-left: 15px;
            }

            .submenu.show {
                display: block;
            }
    </style>


</head>

<body>

    <!-- SIDEBAR -->
    <div id="sidebar" class="sidebar">

        <div class="sidebar-header row m-0">

            <div class="col-md-10">
                <h4>Inventory</h4>
            </div>

            <div class="col-md-2 text-end">
                <button class="toggle-btn" onclick="toggleSidebar()">
                    ☰
                </button>
            </div>

        </div>

        <!-- DASHBOARD -->
        <a href="/Home">Dashboard</a>

        <!-- DYNAMIC ROLE MENU -->
        <div id="menuContainer"></div>

        <!-- LOGOUT -->
        @* <a href="javascript:void(0)" onclick="logout()">Logout</a> *@
        <a href="javascript:void(0)" onclick="showLogoutModal()">Logout</a>

    </div>

    <!-- FLOATING BUTTON -->
    <button id="floatingToggle" class="floating-btn" onclick="toggleSidebar()">
        ☰
    </button>

    <!-- MAIN CONTENT -->
    <div id="content" class="content">

        <!-- TOPBAR -->
        <div class="topbar">

            <div>
                Welcome, @User.Identity.Name
            </div>

            <div>
                <button class="btn btn-sm btn-outline-primary" onclick="reloadPage()">
                    🔄 Reload
                </button>
            </div>

        </div>

        <!-- PAGE BODY -->
        <div style="margin-top:20px;">

            @RenderBody()

            @RenderSection("Scripts", required: false)

        </div>

    </div>



    <!-- LOGOUT MODAL -->
    <div class="modal fade" id="logoutModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title">Confirm Logout</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    Are you sure you want to logout?
                </div>

                <div class="modal-footer">
                    <button class="btn btn-secondary" data-bs-dismiss="modal">
                        Cancel
                    </button>

                    <button class="btn btn-danger" onclick="confirmLogout()">
                        Logout
                    </button>
                </div>

            </div>
        </div>
    </div>
    <!-- =========================================
         JAVASCRIPT
    ========================================= -->

    <script>

            function showLogoutModal() {
                //console.log("Afjada");
                const modal = new bootstrap.Modal(document.getElementById("logoutModal"));
                modal.show();
            }

            function confirmLogout() {
                doLogout();
            }

            window.addEventListener("storage", function (event) {

                if (event.key === "logout-event") {

                    localStorage.clear();
                    window.location.href = "/Auth/Login";
                }
            });


            // =========================
            // JWT EXP HELPER
            // =========================
            function getTokenExp(token) {

                if (!token) return null;

                const payload = JSON.parse(atob(token.split('.')[1]));
                return payload.exp * 1000;
            }

            function doLogout() {

                localStorage.removeItem("token");
                localStorage.removeItem("username");
                localStorage.removeItem("role");

                // trigger other tabs
                localStorage.setItem("logout-event", Date.now());

                window.location.href = "/Auth/Login";
            }

            // =========================
            // CHECK JWT EXPIRY
            // =========================
            function checkJwtExpiry() {

                const token = localStorage.getItem("token");
                if (!token) return;

                const exp = getTokenExp(token);

                if (!exp) return;

                if (Date.now() >= exp) {

                    alert("Session expired");

                    doLogout(); // your logout function
                }
            }


            // =====================================
            // SIDEBAR TOGGLE
            // =====================================

            function toggleSidebar() {

                const sidebar = document.getElementById("sidebar");
                const content = document.getElementById("content");
                const floatingBtn = document.getElementById("floatingToggle");

                sidebar.classList.toggle("hide");

                content.classList.toggle("full");

                if (sidebar.classList.contains("hide")) {

                    floatingBtn.style.display = "block";

                }
                else {

                    floatingBtn.style.display = "none";

                }
            }

            // =====================================
            // PAGE RELOAD
            // =====================================

            function reloadPage() {

                location.reload();

            }

            // =====================================
            // LOAD SIDEBAR MENUS
            // =====================================

            async function loadSidebarMenus() {

                const token = localStorage.getItem("token");

                if (!token) {

                    window.location.href = "/Auth/Login";

                    return;
                }

                try {

                    const response = await fetch("/api/Menu/by-role", {

                        method: "GET",

                        headers: {
                            "Authorization": "Bearer " + token
                        }

                    });

                    // TOKEN EXPIRED
                    if (response.status === 401) {

                        localStorage.removeItem("token");

                        alert("Session expired. Login again.");

                        window.location.href = "/Auth/Login";

                        return;
                    }

                    const menus = await response.json();

                    //console.log(menus);
                    //console.log("Menus");

                    const container = document.getElementById("menuContainer");

                    container.innerHTML = "";

                    menus
                        .sort((a, b) => a.displayOrder - b.displayOrder)
                        .forEach(menu => {
                            container.innerHTML += createMenuHtml(menu);
                        });

                    @* menus.forEach(menu => {

                        container.innerHTML += createMenuHtml(menu);

                    }); *@

                                                                            }
                catch (error) {

                    console.log(error);

                }
            }

            // =====================================
            // RECURSIVE MENU BUILDER
            // =====================================

            function createMenuHtml(menu) {

                let html = "";

                if (menu.children && menu.children.length > 0) {

                    html += `<div><div class="menu-title"onclick="toggleMenu('menu-${menu.menuId}')">${menu.menuName}</div><div id="menu-${menu.menuId}"class="submenu">`;

                    menu.children
                        .sort((a, b) => a.displayOrder - b.displayOrder)
                        .forEach(child => {
                            html += createMenuHtml(child);
                        });

                    html += `</div></div> `;
                }
                else {

                    html += `<a class="menu-link" href="${menu.link || '#'}"> ${menu.menuName}</a>`;
                }

                return html;
            }

            // =====================================
            // EXPAND COLLAPSE
            // =====================================

            function toggleMenu(id) {

                const element =
                    document.getElementById(id);

                if (!element)
                    return;

                element.classList.toggle("show");
            }

            function navigateMenu(url) {

                if (!url || url === "#") {
                    alert("This menu has no page assigned.");
                    return;
                }

                window.location.href = url;
            }

            // =====================================
            // AUTO LOAD
            // =====================================

            loadSidebarMenus();

    
            // =========================
            // RUN PERIODIC CHECK
            // =========================
            let sessionInterval;

            function startSessionWatcher() {

                sessionInterval = setInterval(async () => {

                    const token = localStorage.getItem("token");

                    if (!token) {
                        clearInterval(sessionInterval);
                        return;
                    }

                    try {

                        const res = await fetch("/api/AuthApi/check-session", {
                            headers: {
                                "Authorization": "Bearer " + token
                            }
                        });

                        if (res.status === 401) {

                            clearInterval(sessionInterval);
                            localStorage.clear();

                            alert("Session expired or logged in from another device.");

                            window.location.href = "/Auth/Login";
                        }

                    } catch (err) {
                        console.error("Session check failed", err);
                    }

                }, 30000);
            }

            // start on page load
            startSessionWatcher();

            window.refreshSidebar = function () {
                loadSidebarMenus();
            };


            document.addEventListener("change", async function (e) {

                if (!e.target.classList.contains("menu-checkbox")) return;

                //console.log("toggle fired");

                const cb = e.target;

                const menuId = parseInt(cb.dataset.menuid);
                const roleId = parseInt(document.getElementById("roleId").value);

                if (!roleId || !menuId) {
                    cb.checked = !cb.checked;
                    return;
                }

                try {
                    const res = await fetch("/api/RoleMenuApi/toggle", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ roleId, menuId })
                    });

                    if (!res.ok) {
                        cb.checked = !cb.checked;
                    }

                } catch (err) {
                    console.error(err);
                    cb.checked = !cb.checked;
                }
            });

    </script>
    <!-- ✅ IMPORTANT: ADD THIS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>

