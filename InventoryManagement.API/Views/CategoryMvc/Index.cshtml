@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/site.css" />

<div id="alertBox" class="alert d-none" role="alert"></div>

<div class="row">

    <!-- CATEGORY FORM -->
    <div class="col-md-12">
        <div class="card p-3 shadow">
            <h5>Category Entry</h5>

            <input type="hidden" id="catId" value="0" />

            <!-- Category Code (read only) -->
            <div class="row align-items-end g-3">
                <div class="col-md-4">
                    <label class="form-label">Category Code</label>
                    <input type="text" id="catCode" class="form-control" disabled />
                </div>

                <!-- Category Name -->
                <div class="col-md-4">
                    <label class="form-label">Category Name</label>
                    <input type="text" id="catName" class="form-control" placeholder="Enter category name" />
                </div>

                <div class="col-md-4 d-flex gap-2">
                    <button class="btn btn-primary w-50" onclick="createCategory()">
                        Create
                    </button>

                    <button class="btn btn-outline-info w-50" onclick="updateCategory()">
                        Update
                    </button>
                </div>
                <p id="msg" class="mt-2 text-success"></p>
            </div>
        </div>
    </div>

    <!-- CATEGORY LIST -->
    <div class="col-md-12">
        <div class="card p-3 shadow">

            <div class="d-flex justify-content-between align-items-center mb-3">

                <h5 class="mb-0">Category List</h5>

                <!-- RIGHT ALIGNED SEARCH -->
                <div style="width: 250px;">
                    <input type="text" id="catSearch" class="form-control form-control-sm"
                           placeholder="Search Category..." onkeyup="filterCats()" />
                </div>

            </div>
            <table class="table table-bordered table-striped mt-2">
                <thead>
                    <tr>
                        <th>Category Code</th>
                        <th>Category Name</th>
                        <th>Action</th>
                    </tr>
                </thead>

                <tbody id="catTable"></tbody>
            </table>

        </div>
    </div>

</div>

@section Scripts {
    <script>

        function filterCats() {

            const filter = document.getElementById("catSearch")
                .value.toLowerCase();

            const table = document.getElementById("catTable");
            let rows = Array.from(table.querySelectorAll("tr"));

            // 1. FILTER
            rows.forEach(row => {

                const catName = row.children[1]?.textContent.toLowerCase() || "";

                row.style.display = catName.includes(filter) ? "" : "none";
            });

            // 2. SORT A-Z ALWAYS (visible rows only)
            rows = rows.filter(r => r.style.display !== "none");

            rows.sort((a, b) => {
                const nameA = a.children[1].textContent.toLowerCase();
                const nameB = b.children[1].textContent.toLowerCase();
                return nameA.localeCompare(nameB);
            });

            // re-append sorted rows
            rows.forEach(row => table.appendChild(row));
        }
        // ==========================
        // LOAD CATEGORIES
        // ==========================
        async function loadCategories() {

            const res = await fetch('/api/CategoryApi');
            const data = await res.json();

            let html = "";

            data.forEach(c => {

                html += `
                                <tr>

                                    <td>${c.catCode}</td>
                                    <td>${c.catName}</td>
                                    <td>
                                        <button class="btn btn-sm btn-warning"
                                                data-id="${c.id}"
                                                data-code="${c.catCode}"
                                                data-name="${c.catName}"
                                                onclick="selectCategory(this)">
                                            Edit
                                        </button>
                                    </td>
                                </tr>
                            `;
            });

            document.getElementById("catTable").innerHTML = html;
        }

        // ==========================
        // SELECT CATEGORY
        // ==========================
        function selectCategory(btn) {

            document.getElementById('catId').value = btn.dataset.id || "";
            document.getElementById('catCode').value = btn.dataset.code || "";
            document.getElementById('catName').value = btn.dataset.name || "";
        }

        // ==========================
        // CLEAR FORM
        // ==========================
        function clearForm() {

            document.getElementById("catId").value = 0;
            document.getElementById("catCode").value = '';
            document.getElementById("catName").value = '';
        }

        // ==========================
        // ALERT
        // ==========================
        function showAlert(message, type = "success") {

            const alertBox = document.getElementById("alertBox");

            alertBox.className = `alert alert-${type}`;
            alertBox.innerText = message;
            alertBox.classList.remove("d-none");

            setTimeout(() => {
                alertBox.classList.add("d-none");
            }, 3000);
        }

        // ==========================
        // CREATE CATEGORY
        // ==========================
        async function createCategory() {

            const name = document.getElementById("catName").value.trim();

            if (!name) {
                showAlert("Category name required", "warning");
                return;
            }

            const res = await fetch('/api/CategoryApi/create', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    catName: name
                })
            });

            const result = await res.json();

            if (res.ok) {
                showAlert(result.message, "success");
                document.getElementById("msg").style.color = "green";
                document.getElementById("msg").innerText = result.message;
                clearForm();
                loadCategories();
            }
            else {
                document.getElementById("msg").style.color = "red";
                document.getElementById("msg").innerText = result.message;
                showAlert(result.message || "Error", "danger");
            }

        }

        // ==========================
        // UPDATE CATEGORY
        // ==========================
        async function updateCategory() {

            const id = parseInt(document.getElementById("catId").value);
            const name = document.getElementById("catName").value.trim();

            if (id <= 0) {
                showAlert("Select a category first", "warning");
                return;
            }

            const res = await fetch('/api/CategoryApi/update', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    id: id,
                    catName: name
                })
            });

            const result = await res.json();

            if (res.ok) {
                document.getElementById("msg").style.color = "green";
                document.getElementById("msg").innerText = result.message;
                showAlert(result.message, "success");
                clearForm();
                loadCategories();
            }
            else {
                document.getElementById("msg").style.color = "red";
                document.getElementById("msg").innerText = result.message;
                showAlert(result.message || "Error", "danger");
            }

        }

        // ==========================
        // INIT
        // ==========================
        document.addEventListener("DOMContentLoaded", function () {
            clearForm();
            loadCategories();
        });

    </script>
}