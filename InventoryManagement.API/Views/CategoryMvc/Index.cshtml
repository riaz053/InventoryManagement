@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/site.css" />

<div id="alertBox" class="alert d-none" role="alert"></div>

<div class="row">

    <!-- CATEGORY FORM -->
    <div class="col-md-4">
        <div class="card p-3 shadow">

            <h5>Category Entry</h5>

            <input type="hidden" id="catId" value="0" />

            <!-- Category Code (read only) -->
            <div class="mb-3">
                <label class="form-label">Category Code</label>
                <input type="text" id="catCode" class="form-control" disabled />
            </div>

            <!-- Category Name -->
            <div class="mb-3">
                <label class="form-label">Category Name</label>
                <input type="text" id="catName" class="form-control" placeholder="Enter category name" />
            </div>

            <div class="d-flex gap-2">
                <button class="btn btn-primary w-50" onclick="createCategory()">
                    Create
                </button>

                <button class="btn btn-outline-info w-50" onclick="updateCategory()">
                    Update
                </button>
            </div>
            <p id="msg" class="mt-2 text-success"></p>
        </div>
    </div>

    <!-- CATEGORY LIST -->
    <div class="col-md-8">
        <div class="card p-3 shadow">

            <h5>Category List</h5>

            <table class="table table-bordered table-striped mt-2">
                <thead>
                    <tr>
                        <th>Category Code</th>
                        <th>Category Name</th>
                    </tr>
                </thead>

                <tbody id="catTable"></tbody>
            </table>

        </div>
    </div>

</div>

@section Scripts {
    <script>

        // ==========================
        // LOAD CATEGORIES
        // ==========================
        async function loadCategories() {

            const res = await fetch('/api/CategoryApi');
            const data = await res.json();

            let html = "";

            data.forEach(c => {

                html += `
                                                                        <tr onclick="selectCategory(this)"
                                                                            data-id="${c.id}"
                                                                            data-code="${c.catCode}"
                                                                            data-name="${c.catName}">

                                                                            <td>${c.catCode}</td>
                                                                            <td>${c.catName}</td>
                                                                        </tr>
                                                                    `;
            });

            document.getElementById("catTable").innerHTML = html;
        }

        // ==========================
        // SELECT CATEGORY
        // ==========================
        function selectCategory(row) {

            document.getElementById("catId").value = row.dataset.id;
            document.getElementById("catCode").value = row.dataset.code;
            document.getElementById("catName").value = row.dataset.name;
        }

        // ==========================
        // CLEAR FORM
        // ==========================
        function clearForm() {

            document.getElementById("catId").value = 0;
            document.getElementById("catCode").value = '';
            document.getElementById("catName").value = '';
        }

        // ==========================
        // ALERT
        // ==========================
        function showAlert(message, type = "success") {

            const alertBox = document.getElementById("alertBox");

            alertBox.className = `alert alert-${type}`;
            alertBox.innerText = message;
            alertBox.classList.remove("d-none");

            setTimeout(() => {
                alertBox.classList.add("d-none");
            }, 3000);
        }

        // ==========================
        // CREATE CATEGORY
        // ==========================
        async function createCategory() {

            const name = document.getElementById("catName").value.trim();

            if (!name) {
                showAlert("Category name required", "warning");
                return;
            }

            const res = await fetch('/api/CategoryApi/create', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    catName: name
                })
            });

            const result = await res.json();

            if (res.ok) {
                showAlert(result.message, "success");
                document.getElementById("msg").style.color = "green";
                document.getElementById("msg").innerText = result.message;
                clearForm();
                loadCategories();
            }
            else {
                document.getElementById("msg").style.color = "red";
                document.getElementById("msg").innerText = result.message;
                showAlert(result.message || "Error", "danger");
            }

        }

        // ==========================
        // UPDATE CATEGORY
        // ==========================
        async function updateCategory() {

            const id = parseInt(document.getElementById("catId").value);
            const name = document.getElementById("catName").value.trim();

            if (id <= 0) {
                showAlert("Select a category first", "warning");
                return;
            }

            const res = await fetch('/api/CategoryApi/update', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    id: id,
                    catName: name
                })
            });

            const result = await res.json();

            if (res.ok) {
                document.getElementById("msg").style.color = "green";
                document.getElementById("msg").innerText = result.message;
                showAlert(result.message, "success");
                clearForm();
                loadCategories();
            }
            else {
                document.getElementById("msg").style.color = "red";
                document.getElementById("msg").innerText = result.message;
                showAlert(result.message || "Error", "danger");
            }

        }

        // ==========================
        // INIT
        // ==========================
        document.addEventListener("DOMContentLoaded", function () {
            clearForm();
            loadCategories();
        });

    </script>
}