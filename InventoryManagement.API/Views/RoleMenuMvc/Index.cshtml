@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">

    <div class="card p-3">

        <h5>Role Menu Assignment</h5>

        <select id="roleId" class="form-control mb-3" onchange="loadMenusonChange()">
            <option value="">Select Role</option>
        </select>

        <div id="menuTree"></div>

    </div>

</div>
<div id="pageLoader" class="page-loader hidden">
    <div class="spinner"></div>
    <div class="loader-text">Loading Menus...</div>
</div>
<script>
    let roleIdGlobal = 0;
    let assignedMenus = new Set();
    // =========================
    // LOAD ROLES
    // =========================
    async function loadRoles() {

        const res = await fetch('/api/RolesApi');
        const data = await res.json();
        //console.log(data);
        let html = `<option value="">Select Role</option>`;

        data.forEach(r => {
            html += `<option value="${r.id}">${r.roleName}</option>`;
        });

        document.getElementById("roleId").innerHTML = html;
    }

    // =========================
    // LOAD MENUS ON ROLE CHANGE
    // =========================
    async function loadMenusonChange() {

        const roleId = document.getElementById("roleId").value;

        if (!roleId) {
            assignedMenus = new Set();
            await loadMenus();
            return;
        }

        const res = await fetch(`/api/RoleMenuApi/by-role/${roleId}`);
        const data = await res.json();

        assignedMenus = new Set(data);

        // ONLY UPDATE CHECKBOXES (NO REBUILD)
        document.querySelectorAll("#menuTree input[type='checkbox']")
            .forEach(cb => {
                const id = parseInt(cb.dataset.menuid);
                cb.checked = assignedMenus.has(id);
            });
    }

    async function loadMenus() {

        showLoader();

        try {

            const res = await fetch(`/api/Menu`);
            const allMenus = await res.json();

            let html = "";

            const level1 = allMenus.filter(x => x.parentMenuId === null);

            level1.forEach(l1 => {

                html += `<div class="level-1">▶ ${l1.menuName}</div>`;

                const level2 = allMenus.filter(x => x.parentMenuId === l1.menuId);

                level2.forEach(l2 => {

                    const level3 = allMenus.filter(x => x.parentMenuId === l2.menuId);

                    if (level3.length > 0) {

                        html += `<div class="level-2">&nbsp;---▶ ${l2.menuName}</div>`;

                        level3.forEach(l3 => {

                            const hasLink = l3.link && l3.link.trim() !== "";

                            html += `
                            <div class="level-3">
                                <span>&nbsp;-------▶ ${l3.menuName}</span>

                                ${hasLink ? `
                                    <input type="checkbox"
                                        class="menu-checkbox"
                                        data-menuid="${l3.menuId}" />
                                    
                                ` : ""}
                            </div>
                        `;
                        });

                    } else {

                        const hasLink = l2.link && l2.link.trim() !== "";

                        html += `
                        <div class="level-2">
                            &nbsp;--▶ ${l2.menuName}

                            ${hasLink ? `
                                <input type="checkbox"
                                        class="menu-checkbox"
                                        data-menuid="${l2.menuId}" />
                               
                            ` : ""}
                        </div>
                    `;
                    }
                });
            });

            document.getElementById("menuTree").innerHTML = html;

        } finally {
            hideLoader();
        }
    }

    document.addEventListener("DOMContentLoaded", function () {
        loadRoles();
        loadMenus();
    });

    function showLoader() {
        document.getElementById("pageLoader").classList.remove("hidden");
    }

    function hideLoader() {
        document.getElementById("pageLoader").classList.add("hidden");
    }

</script>