@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .btn-xs {
        padding: 2px 6px;
        font-size: 11px;
        line-height: 1.2;
    }
</style>
<div class="container mt-3">
    <h3>Menu Management</h3>

    <div class="row mt-3">
        <div class="col-md-12">
            <div class="card shadow-sm">
                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center mb-3">

                        <h5 class="mb-0">Menu List</h5>

                        <div class="d-flex gap-2">

                            <input type="text" id="searchMenu" class="form-control" placeholder="Search menu..."
                                   style="width:250px;" onkeyup="filterMenus()" />

                            <button class="btn btn-primary" onclick="openAddMenuModal()">
                                Add Menu
                            </button>

                        </div>

                    </div>

                    <table class="table table-bordered table-hover table-sm">
                        <thead class="table-light">
                            <tr>
                                <th>Code</th>
                                <th>Name</th>
                                <th>Link</th>
                                <th>Parent</th>
                                <th>Order</th>
                                <th>Status</th>
                                <th width="120">Action</th>
                            </tr>
                        </thead>
                        <tbody id="menuTable"></tbody>
                    </table>

                </div>
            </div>
        </div>

        
    </div>
</div>

<div class="modal fade" id="menuModal" tabindex="-1">

    <div class="modal-dialog modal-lg">

        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Menu Entry</h5>

                <button type="button" class="btn-close" data-bs-dismiss="modal">
                </button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="menuId" />
                <input type="hidden" id="menuCode" />

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label class="form-label">
                            Menu Name
                        </label>

                        <input type="text" id="menuName" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">
                            Link
                        </label>

                        <input type="text" id="link" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">
                            Icon
                        </label>

                        <input type="text" id="icon" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">
                            Display Order
                        </label>

                        <input type="number" id="displayOrder" class="form-control" value="0" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">
                            Parent Menu
                        </label>

                        <select id="parentMenuId" class="form-select">
                            <option value="">
                                -- None --
                            </option>
                        </select>
                    </div>

                    <div class="col-md-6 mb-3 d-flex align-items-center">

                        <div class="form-check mt-4">

                            <input type="checkbox" id="isActive" class="form-check-input" checked />

                            <label class="form-check-label">
                                Active
                            </label>

                        </div>

                    </div>

                </div>

            </div>

            <div class="modal-footer">

                <button class="btn btn-secondary" data-bs-dismiss="modal">
                    Close
                </button>

                <button class="btn btn-primary" onclick="saveMenu()">
                    Save
                </button>

            </div>

        </div>

    </div>

</div>




<script>
    const apiUrl = "/api/Menu";

    // =========================
    // INITIAL LOAD
    // =========================
    document.addEventListener("DOMContentLoaded", function () {
        loadMenus();
        loadParentMenus();
    });

    // =========================
    // LOAD ALL MENUS
    // =========================
    async function loadMenus() {
        try {
            const res = await fetch(apiUrl);

            console.log(res);

            if (!res.ok) {
                throw new Error("Failed to load menus.");
            }

            let data = await res.json();

            // Sort by DisplayOrder
            data.sort((a, b) => a.displayOrder - b.displayOrder);

            // Read selected filter
            const filter = "";//document.getElementById("menuTypeFilter").value;

            if (filter === "parent") {
                data = data.filter(x =>
                    !x.link || x.link.trim() === ""
                );
            }
            else if (filter === "child") {
                data = data.filter(x =>
                    x.link && x.link.trim() !== ""
                );
            }

            const tbody = document.getElementById("menuTable");
            tbody.innerHTML = "";

            data.forEach(x => {
                const row = `
                <tr>
                    <td>${x.menuCode ?? ""}</td>
                    <td>${x.menuName ?? ""}</td>
                    <td>${x.link ?? ""}</td>
                    <td>${x.parentMenuName ?? ""}</td>
                    <td>${x.displayOrder ?? 0}</td>
                    <td>
                        ${x.isActive
                        ? '<span class="badge bg-success">Active</span>'
                        : '<span class="badge bg-danger">Inactive</span>'}
                    </td>
                    <td>
                        <button class="btn btn-xs btn-warning"
                                onclick="editMenu(${x.menuId})">
                            <i class="fa-solid fa-pen-to-square"></i>
                        </button>
                        <button class="btn btn-xs btn-danger"
                                onclick="deleteMenu(${x.menuId})">
                            <i class="fa fa-ban" aria-hidden="true"></i>
                        </button>
                    </td>
                </tr>
            `;

                tbody.innerHTML += row;
            });
        }
        catch (error) {
            console.error(error);
            alert("Failed to load menus.");
        }
    }

    // =========================
    // LOAD PARENT MENU DROPDOWN
    // =========================
    async function loadParentMenus(selectedValue = "") {
        try {
            const res = await fetch("/api/Menu");

            if (!res.ok) {
                console.log("API failed");
                return;
            }

            const data = await res.json();

            const ddl = document.getElementById("parentMenuId");

            if (!ddl) {
                console.error("Dropdown not found");
                return;
            }

            ddl.innerHTML = '<option value="">-- None --</option>';

            // 🔥 CORRECT PARENT FILTER
            const parents = data.filter(x =>
                x.isActive === true &&
                (!x.link || x.link.trim() === "")
            );

            parents.forEach(x => {
                ddl.innerHTML += `
                <option value="${x.menuId}">
                    ${x.menuName}
                </option>`;
            });

            if (selectedValue) {
                ddl.value = selectedValue;
            }
        }
        catch (err) {
            console.error("Parent menu load error:", err);
        }
    }

    // =========================
    // SAVE (CREATE / UPDATE)
    // =========================
    async function saveMenu() {

        try {
            const menuId = document.getElementById("menuId").value;

            const payload = {
                menuId: menuId ? parseInt(menuId) : 0,

                menuName: document.getElementById("menuName").value.trim(),

                menuCode: document.getElementById("menuCode").value.trim() || null,

                link: document.getElementById("link").value.trim() || null,

                icon: document.getElementById("icon").value.trim() || null,

                displayOrder: parseInt(
                    document.getElementById("displayOrder").value || "0"
                ),

                parentMenuId:
                    document.getElementById("parentMenuId").value
                        ? parseInt(document.getElementById("parentMenuId").value)
                        : null,

                isActive:
                    document.getElementById("isActive").checked
            };

            if (!payload.menuName) {
                alert("Menu Name is required.");
                return;
            }

            const url = menuId
                ? `${apiUrl}/update`
                : `${apiUrl}/create`;

            const res = await fetch(url, {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify(payload)
            });

            const result = await res.json();

            if (!res.ok) {
                alert(result.message || "Operation failed.");
                return;
            }

            @* alert(result.message); *@

                bootstrap.Modal
                    .getInstance(
                        document.getElementById("menuModal")
                    )
                    ?.hide();

            clearForm();
            await loadMenus();
            await loadParentMenus();

            if (window.refreshSidebar) {
                window.refreshSidebar();
            }
        }
        catch (error) {
            console.error(error);
            alert("Failed to save menu.");
        }
    }

    // =========================
    // EDIT
    // =========================
    async function editMenu(id) {
        try {
            const res = await fetch(`${apiUrl}/${id}`);

            if (!res.ok) {
                throw new Error("Failed to load menu.");
            }

            const x = await res.json();

            document.getElementById("menuId").value = x.menuId;
            document.getElementById("menuName").value = x.menuName ?? "";
            document.getElementById("menuCode").value = x.menuCode ?? "";
            document.getElementById("link").value = x.link ?? "";
            document.getElementById("icon").value = x.icon ?? "";
            document.getElementById("displayOrder").value =
                x.displayOrder ?? 0;
            document.getElementById("isActive").checked =
                x.isActive ?? true;

            await loadParentMenus(x.parentMenuId);
        }
        catch (error) {
            console.error(error);
            alert("Failed to load menu for editing.");
        }

        const modal =
            new bootstrap.Modal(
                document.getElementById("menuModal")
            );

        modal.show();
    }

    // =========================
    // DELETE (SOFT DELETE)
    // =========================
    async function deleteMenu(id) {
        if (!confirm("Are you sure you want to disable this menu?"))
            return;

        try {
            const res = await fetch(`${apiUrl}/${id}`, {
                method: "DELETE"
            });

            const result = await res.json();

            if (!res.ok) {
                alert(result.message || "Delete failed.");
                return;
            }

            alert(result.message);

            await loadMenus();
            await loadParentMenus();
        }
        catch (error) {
            console.error(error);
            alert("Failed to disable menu.");
        }
    }

    // =========================
    // CLEAR FORM
    // =========================
    function clearForm() {
        document.getElementById("menuId").value = "";
        document.getElementById("menuName").value = "";
        document.getElementById("link").value = "";
        document.getElementById("icon").value = "";
        document.getElementById("displayOrder").value = 0;
        document.getElementById("parentMenuId").value = "";
        document.getElementById("isActive").checked = true;
    }

    function openAddMenuModal() {

        clearForm();

        loadParentMenus();

        const modal =
            new bootstrap.Modal(
                document.getElementById("menuModal")
            );

        modal.show();
    }

    function filterMenus() {

        const keyword =
            document.getElementById("searchMenu")
                .value
                .toLowerCase();

        const rows =
            document.querySelectorAll("#menuTable tr");

        rows.forEach(row => {

            row.style.display =
                row.innerText
                    .toLowerCase()
                    .includes(keyword)
                    ? ""
                    : "none";
        });
    }




</script>