@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-3">

    <h3>Menu Management</h3>

    <div class="row mt-3">

        <!-- FORM -->
        <div class="col-md-4">
            <div class="card p-3">

                <input type="hidden" id="menuId" />

                <!-- MENU CODE -->
                <div class="mb-2">
                    <label>Menu Code</label>
                    <input type="text" id="menuCode" class="form-control" />
                </div>

                <!-- MENU NAME -->
                <div class="mb-2">
                    <label>Menu Name</label>
                    <input type="text" id="menuName" class="form-control" />
                </div>

                <!-- LINK -->
                <div class="mb-2">
                    <label>Link</label>
                    <input type="text" id="link" class="form-control" placeholder="/MenuMvc" />
                </div>

                <!-- ICON -->
                <div class="mb-2">
                    <label>Icon</label>
                    <input type="text" id="icon" class="form-control" />
                </div>

                <!-- DISPLAY ORDER -->
                <div class="mb-2">
                    <label>Display Order</label>
                    <input type="number" id="displayOrder" class="form-control" value="0" />
                </div>

                <!-- PARENT MENU -->
                <div class="mb-2">
                    <label>Parent Menu</label>
                    <select id="parentMenuId" class="form-control">
                        <option value="">-- None --</option>
                    </select>
                </div>

                <!-- IS GROUP -->
                <div class="mb-2 form-check">
                    <input type="checkbox" id="isGroup" class="form-check-input" />
                    <label class="form-check-label">Is Group Menu</label>
                </div>

                <!-- ACTIVE -->
                <div class="mb-2 form-check">
                    <input type="checkbox" id="isActive" class="form-check-input" checked />
                    <label class="form-check-label">Active</label>
                </div>

                <button class="btn btn-primary w-100" onclick="saveMenu()">Save</button>
                <button class="btn btn-secondary w-100 mt-2" onclick="clearForm()">Clear</button>

            </div>
        </div>

        <!-- TABLE -->
        <div class="col-md-8">
            <div class="card p-3">

                <table class="table table-bordered table-sm">
                    <thead>
                        <tr>
                            <th>Code</th>
                            <th>Name</th>
                            <th>Link</th>
                            <th>Parent</th>
                            <th>Group</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody id="menuTable"></tbody>
                </table>

            </div>
        </div>

    </div>
</div>

<script>

    const apiUrl = "/api/Menu";

    // LOAD MENUS
    async function loadMenus() {
        const res = await fetch(apiUrl);
        const data = await res.json();

        let rows = "";

        data.forEach(x => {
            rows += `
        <tr>
            <td>${x.menuCode || ''}</td>
            <td>${x.menuName}</td>
            <td>${x.link || ''}</td>
            <td>${x.parentMenuName || ''}</td>
            <td>${x.isGroup ? "Yes" : "No"}</td>
            <td>${x.isActive ? "Active" : "Inactive"}</td>
            <td>
                <button class="btn btn-sm btn-info" onclick='editMenu(${JSON.stringify(x)})'>Edit</button>
                <button class="btn btn-sm btn-danger" onclick='deleteMenu(${x.menuId})'>Disable</button>
            </td>
        </tr>`;
        });

        document.getElementById("menuTable").innerHTML = rows;
    }

    // LOAD PARENT MENU DROPDOWN
    async function loadParentMenus() {
        const res = await fetch(apiUrl);
        const data = await res.json();

        const ddl = document.getElementById("parentMenuId");
        ddl.innerHTML = `<option value="">-- None --</option>`;

        data
            .filter(x => x.isGroup === true)
            .forEach(x => {
                ddl.innerHTML += `
                <option value="${x.menuId}">
                    ${x.menuName}
                </option>`;
            });
    }

    // SAVE
    async function saveMenu() {

        const id = document.getElementById("menuId").value;

        const obj = {
            menuId: id ? parseInt(id) : 0,
            menuCode: document.getElementById("menuCode").value,
            menuName: document.getElementById("menuName").value,
            link: document.getElementById("link").value,
            icon: document.getElementById("icon").value,
            displayOrder: parseInt(document.getElementById("displayOrder").value),
            parentMenuId: document.getElementById("parentMenuId").value || null,
            isGroup: document.getElementById("isGroup").checked,
            isActive: document.getElementById("isActive").checked
        };

        const url = id ? "/api/Menu/update" : "/api/Menu/create";

        const res = await fetch(url, {
            method: "POST",
            headers: {
                "Content-Type": "application/json"
            },
            body: JSON.stringify(obj)
        });

        const result = await res.json();
        alert(result.message);

        clearForm();
        loadMenus();
        loadParentMenus();
    }

    // EDIT
    function editMenu(x) {
        document.getElementById("menuId").value = x.menuId;
        document.getElementById("menuCode").value = x.menuCode || "";
        document.getElementById("menuName").value = x.menuName || "";
        document.getElementById("link").value = x.link || "";
        document.getElementById("icon").value = x.icon || "";
        document.getElementById("displayOrder").value = x.displayOrder;
        document.getElementById("parentMenuId").value = x.parentMenuId || "";
        document.getElementById("isGroup").checked = x.isGroup;
        document.getElementById("isActive").checked = x.isActive;
    }

    // DELETE (SOFT)
    async function deleteMenu(id) {

        if (!confirm("Disable this menu?")) return;

        const res = await fetch(`${apiUrl}/${id}`, {
            method: "DELETE"
        });

        const result = await res.json();
        alert(result.message);

        loadMenus();
        loadParentMenus();
    }

    // CLEAR
    function clearForm() {
        document.getElementById("menuId").value = "";
        document.getElementById("menuCode").value = "";
        document.getElementById("menuName").value = "";
        document.getElementById("link").value = "";
        document.getElementById("icon").value = "";
        document.getElementById("displayOrder").value = 0;
        document.getElementById("parentMenuId").value = "";
        document.getElementById("isGroup").checked = false;
        document.getElementById("isActive").checked = true;
    }

    // INIT
    loadMenus();
    loadParentMenus();

</script>