@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<link rel="stylesheet" href="~/css/site.css" />

<div id="alertBox" class="alert d-none" role="alert"></div>

<div class="row">

    <!-- Role Form -->
    <div class="col-md-12">
        <div class="card p-3 shadow">

            <h5 class="mb-3">Role Entry</h5>

            <input type="hidden" id="roleId" value="0" />

            <div class="row align-items-end g-3">

                <!-- Role Code -->
                <div class="col-md-4">
                    <label class="form-label">Role Code</label>
                    <input type="text" id="roleCode" class="form-control" disabled />
                </div>

                <!-- Role Name -->
                <div class="col-md-4">
                    <label class="form-label">Role Name</label>
                    <input type="text" id="roleName" class="form-control" placeholder="Enter role name" />
                </div>

                <!-- Buttons -->
                <div class="col-md-4 d-flex gap-2">
                    <button type="button" class="btn btn-primary flex-fill" onclick="createRole()">
                        Create
                    </button>

                    <button type="button" class="btn btn-outline-info flex-fill" onclick="updateRole()">
                        Update
                    </button>
                </div>

            </div>

        </div>
    </div>

    <!-- Role List -->
    <div class="col-md-12">
        <div class="card p-3 shadow">

            <div class="d-flex justify-content-between align-items-center mb-3">

                <h5 class="mb-0">Role List</h5>

                <!-- RIGHT ALIGNED SEARCH -->
                <div style="width: 250px;">
                    <input type="text" id="roleSearch" class="form-control form-control-sm"
                           placeholder="Search role name..." onkeyup="filterRoles()" />
                </div>

            </div>

            <table class="table table-bordered table-striped mt-2">
                <thead>
                    <tr>
                        <th>Role Code</th>
                        <th>Role Name</th>
                        <th>Action</th>
                    </tr>
                </thead>

                <tbody id="roleTable"></tbody>
            </table>

        </div>
    </div>

</div>

@section Scripts {
    <script>
        // ==========================
        // LOAD ROLES
        // ==========================
        function filterRoles() {

            const filter = document.getElementById("roleSearch")
                .value.toLowerCase();

            const table = document.getElementById("roleTable");
            let rows = Array.from(table.querySelectorAll("tr"));

            // 1. FILTER
            rows.forEach(row => {

                const roleName = row.children[1]?.textContent.toLowerCase() || "";

                row.style.display = roleName.includes(filter) ? "" : "none";
            });

            // 2. SORT A-Z ALWAYS (visible rows only)
            rows = rows.filter(r => r.style.display !== "none");

            rows.sort((a, b) => {
                const nameA = a.children[1].textContent.toLowerCase();
                const nameB = b.children[1].textContent.toLowerCase();
                return nameA.localeCompare(nameB);
            });

            // re-append sorted rows
            rows.forEach(row => table.appendChild(row));
        }

        async function loadRoles() {
            try {
                const res = await fetch('/api/RolesApi');

                if (!res.ok) {
                    throw new Error('Failed to load roles');
                }

                const data = await res.json();

                //console.log(data);

                let html = '';
                // onclick="selectRole(this)"
                data.forEach(r => {
                    html += `<tr>
                                        <td>${r.roleCode}</td>
                                        <td>${r.roleName}</td>

                                        <td>
                                            <button class="btn btn-sm btn-warning"
                                                    data-id="${r.id}"
                                                    data-code="${r.roleCode}"
                                                    data-name="${r.roleName}"
                                                    onclick="selectRole(this)">
                                                Edit
                                            </button>
                                        </td>
                                    </tr>`;
                });
                //});

                @* data.forEach(r => {
                    html += `
                <tr
                data-id="${r.id}"
                data-code="${r.roleCode}"
                data-name="${r.roleName}">
                <td>${r.roleCode}</td>
                <td>${r.roleName}</td>
                <td>
                <button class="btn btn-xs btn-warning"
                onclick="selectRole(this)">
                Edit
                </button>
                </td>
                </tr>`;
                }); *@

                    document.getElementById('roleTable').innerHTML = html;
            }
            catch (error) {
                console.error(error);
                showAlert('Failed to load roles', 'danger');
            }
        }

        // ==========================
        // SELECT ROLE
        // ==========================
        function selectRole(btn) {

            document.getElementById('roleId').value = btn.dataset.id || "";
            document.getElementById('roleCode').value = btn.dataset.code || "";
            document.getElementById('roleName').value = btn.dataset.name || "";
        }

        
        // ==========================
        // CLEAR FORM
        // ==========================
        function clearForm() {
            document.getElementById('roleId').value = 0;
            document.getElementById('roleCode').value = '';
            document.getElementById('roleName').value = '';
        }

        // ==========================
        // SHOW ALERT
        // ==========================
        function showAlert(message, type = 'success') {
            const alertBox = document.getElementById('alertBox');

            alertBox.className = `alert alert-${type}`;
            alertBox.innerText = message;
            alertBox.classList.remove('d-none');

            setTimeout(() => {
                alertBox.classList.add('d-none');
            }, 3000);
        }

        // ==========================
        // CREATE ROLE
        // ==========================
        async function createRole() {
            const roleName = document.getElementById('roleName').value.trim();

            if (!roleName) {
                showAlert('Role name is required', 'warning');
                return;
            }

            const res = await fetch('/api/RolesApi/create', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    rName: roleName
                })
            });

            const result = await res.json();

            if (res.ok) {
                showAlert(result.message, 'success');
                clearForm();
                loadRoles();
            }
            else {
                showAlert(result.message || 'Failed to create role', 'danger');
            }

            loadRoles();
        }

        // ==========================
        // UPDATE ROLE
        // ==========================
        async function updateRole() {
            const id = parseInt(document.getElementById('roleId').value);
            const roleName = document.getElementById('roleName').value.trim();

            if (id <= 0) {
                showAlert('Please select a role first', 'warning');
                return;
            }

            if (!roleName) {
                showAlert('Role name is required', 'warning');
                return;
            }

            const res = await fetch('/api/RolesApi/update', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    id: id,
                    rName: roleName
                })
            });

            const result = await res.json();

            if (res.ok) {
                showAlert(result.message, 'success');
                clearForm();
                loadRoles();
            }
            else {
                showAlert(result.message || 'Failed to update role', 'danger');
            }
        }

        // ==========================
        // PAGE INIT
        // ==========================
        document.addEventListener('DOMContentLoaded', function () {
            clearForm();
            loadRoles();
        });
    </script>
}