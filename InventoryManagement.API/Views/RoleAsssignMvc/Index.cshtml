@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">

    <div class="card shadow p-3">

        <h4>Role Menu Permission</h4>

        <div class="row mb-3">

            <div class="col-md-4">
                <select id="roleId" class="form-control" onchange="loadPermissions()">
                    <option value="">Select Role</option>
                </select>
            </div>

            <div class="col-md-2">
                <button class="btn btn-success w-100" onclick="savePermissions()">
                    Save
                </button>
            </div>

        </div>

        <table class="table table-bordered">

            <thead class="table-dark">
                <tr>
                    <th>Menu</th>
                    <th>Permissions</th>
                </tr>
            </thead>

            <tbody id="permissionTable"></tbody>

        </table>

    </div>

</div>

<script>

    // ============================
    // LOAD ROLES
    // ============================
    async function loadRoles() {

        const res = await fetch('/api/RolesApi');
        const data = await res.json();

        let html = `<option value="">Select Role</option>`;

        data.forEach(r => {
            html += `
                <option value="${r.id}">
                    ${r.rName}
                </option>
            `;
        });

        document.getElementById("roleId").innerHTML = html;
    }

    // ============================
    // LOAD MATRIX
    // ============================
    async function loadPermissions() {

        const roleId =
            document.getElementById("roleId").value;

        if (!roleId) return;

        const res = await fetch(
            `/api/RoleMenuPermissionApi/${roleId}`
        );

        const data = await res.json();

        const tbody =
            document.getElementById("permissionTable");

        tbody.innerHTML = "";

        data.forEach(m => {

            let permissionHtml = "";

            m.permissions.forEach(p => {

                permissionHtml += `
                    <label class="me-3">
                        <input type="checkbox"
                               class="permission-checkbox"
                               data-menuid="${m.menuId}"
                               data-permissionid="${p.permissionId}"
                               ${p.isAllowed ? "checked" : ""} />

                        ${p.permissionName}
                    </label>
                `;
            });

            tbody.innerHTML += `
                <tr>
                    <td>${m.menuName}</td>
                    <td>${permissionHtml}</td>
                </tr>
            `;
        });
    }

    // ============================
    // SAVE
    // ============================
    async function savePermissions() {

        const roleId = parseInt(
            document.getElementById("roleId").value
        );

        if (!roleId) {
            alert("Select role");
            return;
        }

        const checkboxes =
            document.querySelectorAll(".permission-checkbox");

        const permissions = [];

        checkboxes.forEach(cb => {

            permissions.push({
                menuId: parseInt(cb.dataset.menuid),
                permissionId: parseInt(cb.dataset.permissionid),
                isAllowed: cb.checked
            });

        });

        const payload = {
            roleId: roleId,
            permissions: permissions
        };

        const res = await fetch(
            '/api/RoleMenuPermissionApi/save',
            {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(payload)
            });

        const result = await res.json();

        if (res.ok) {
            alert(result.message);
        }
        else {
            alert("Save failed");
        }
    }

    // ============================
    // INIT
    // ============================
    loadRoles();

</script>